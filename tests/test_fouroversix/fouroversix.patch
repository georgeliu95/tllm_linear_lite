--- a/src/fouroversix/quantize/quantized_tensor.py
+++ b/src/fouroversix/quantize/quantized_tensor.py
@@ -1,3 +1,5 @@
+from __future__ import annotations
+
 from dataclasses import dataclass
 
 import torch
@@ -199,6 +201,33 @@ class QuantizedTensor:
 
         return result
 
+    def to(
+        self,
+        dtype: torch.dtype | torch.device,
+        *args: object,
+        **kwargs: object,
+    ) -> torch.Tensor | QuantizedTensor:
+        """
+        If dtype is a high-precision dtype (e.g. torch.bfloat16), return the
+        dequantized tensor. If dtype is a device, return a copy on that device.
+        """
+        if isinstance(dtype, torch.dtype):
+            if dtype in (torch.bfloat16, torch.float16, torch.float32):
+                return self.dequantize(dtype=dtype)
+            else:
+                return self.dequantize(dtype=torch.float32).to(dtype)
+        if isinstance(dtype, torch.device):
+            return QuantizedTensor(
+                self.values.to(dtype, *args, **kwargs),
+                self.scale_factors.to(dtype, *args, **kwargs),
+                self.amax.to(dtype, *args, **kwargs) if self.amax is not None else self.amax,
+                self.dtype,
+                self.original_shape,
+                self.scale_rule,
+                self.padded_shape,
+            )
+        raise TypeError(f"to() requires torch.dtype or torch.device; got {type(dtype)}")
+
     @property
     def device(self) -> torch.device:
         """Get device of the values in this tensor."""
